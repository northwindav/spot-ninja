# Spot-Ninja Environment Configuration
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

# OpenTopography SRTM API Key (optional; if using WindNinja's built-in DEM fetch)
# Get from: https://opentopography.org/
CUSTOM_SRTM_API_KEY=your_api_key_here

# MSC GeoMet API (optional; no authentication required for basic access)
# Default endpoint: https://api.weather.gc.ca/
GEOMET_API_BASE=https://api.weather.gc.ca

# AWS CLI region for CanElevation S3 bucket access
AWS_REGION=ca-central-1

# Optional: Synoptic weather station API (for point initialization)
# SYNOPTIC_API_TOKEN=your_token_here

# Optional: Custom data paths (default: ./data/)
# DATA_DIR=./data
# DEM_DIR=./data/dems
# WEATHER_DIR=./data/weather
# OUTPUT_DIR=./data/output

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
